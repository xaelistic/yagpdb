# Everdream Bot Environment Config
# Copy this to app.env and fill in your values

# Discord Bot Setup
# Get these from https://discord.com/developers/applications
YAGPDB_OWNER=YOUR_DISCORD_USER_ID
YAGPDB_CLIENTID=YOUR_BOT_CLIENT_ID
YAGPDB_CLIENTSECRET=YOUR_BOT_CLIENT_SECRET
YAGPDB_BOTToken=Bot YOUR_BOT_TOKEN

# Host (change to your domain if using external hosting)
YAGPDB_HOST=localhost

# Email for Let's Encrypt (only needed for external HTTPS)
YAGPDB_EMAIL=your@email.com

# Database
YAGPDB_PQHOST=db
YAGPDB_PQUSERNAME=yagpdb
YAGPDB_PQPASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
YAGPDB_REDIS=redis:6379

# Optional: Logging channels (Discord channel IDs)
# YAGPDB_CONNEVT_CHANNEL=
# YAGPDB_CONNSTATUS_CHANNEL=
# YAGPDB_BOTLEAVESJOINS=

# Optional: External services (leave blank if not using)
# YAGPDB_AYLIENAPPID=
# YAGPDB_AYLIENAPPKEY=
# YAGPDB_OWLBOT_TOKEN=
# YAGPDB_REDDIT_CLIENTID=
# YAGPDB_REDDIT_CLIENTSECRET=
# YAGPDB_REDDIT_REDIRECT=
# YAGPDB_REDDIT_REFRESHTOKEN=
# YAGPDB_REDDIT_DEVUSERNAME=
# GOOGLE_APPLICATION_CREDENTIALS=
# YAGPDB_YOUTUBE_VERIFY_TOKEN=
# YAGPDB_TWITCH_CLIENTID=
# YAGPDB_TWITCH_CLIENTSECRET=
